{
  "manifest_version": 3,
  "name": "Extension Boilerplate",
  "version": "1.37",
  "description": "A minimal browser extension boilerplate.",
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "scripting",
    "clipboardWrite"
  ],
  "commands": {
    "copy-selected-tab-urls": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Copy the highlighted tabs' URLs"
    },
    "copy-all-tab-urls": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Copy all tabs' URLs in the current window"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": "src/icon.svg"
  },
  "icons": {
    "16": "src/icon.svg",
    "48": "src/icon.svg",
    "128": "src/icon.svg"
  }
}
