{
    "manifest_version":  2,
    "name":  "Extension Boilerplate",
    "version": "1.34",
    "description":  "A minimal browser extension boilerplate.",
    "permissions":  [
                        "activeTab",
                        "tabs",
                        "contextMenus",
                        "clipboardWrite"
                    ],
    "commands":  {
                    "copy-selected-tab-urls":  {
                                                  "suggested_key":  {
                                                                       "default":  "Ctrl+Shift+Y"
                                                                   },
                                                  "description":  "Copy the highlighted tabs' URLs"
                                              },
                    "copy-all-tab-urls":  {
                                              "suggested_key":  {
                                                                   "default":  "Ctrl+Shift+U"
                                                               },
                                              "description":  "Copy all tabs' URLs in the current window"
                                          }
                },
    "background":  {
                       "scripts":  [
                                       "src/background.js"
                                   ]
                   },
    "browser_action":  {
                           "default_popup":  "src/popup.html",
                           "default_icon":  {
                                                "16":  "src/icon.svg",
                                                "32":  "src/icon.svg",
                                                "48":  "src/icon.svg",
                                                "128":  "src/icon.svg"
                                            }
                       },
    "icons":  {
                  "16":  "src/icon.svg",
                  "32":  "src/icon.svg",
                  "48":  "src/icon.svg",
                  "128":  "src/icon.svg"
              },
    "browser_specific_settings":  {
                                      "gecko":  {
                                                    "id":  "boilerplate@example.com",
                                                    "strict_min_version":  "109.0"
                                                }
                                  }
}
